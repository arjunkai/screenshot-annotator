{
  "url": "https://opbindr.com",
  "viewports": [
    {
      "name": "desktop",
      "width": 1440,
      "height": 900
    },
    {
      "name": "mobile",
      "width": 390,
      "height": 844
    }
  ],
  "setup": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    }
  ],
  "annotations": [
    {
      "type": "label",
      "selector": "role=button[name=/create your first binder/i]",
      "text": "Click to begin",
      "position": "right",
      "color": "#ef4444"
    },
    {
      "type": "arrow",
      "fromSelector": "role=heading[name=/one piece tcg collection/i]",
      "toSelector": "role=button[name=/create your first binder/i]",
      "fromSide": "bottom",
      "toSide": "top",
      "color": "#ef4444"
    }
  ]
}