{
  "name": "screenshot-annotator",
  "version": "0.2.0",
  "description": "Capture annotated screenshots of any web UI. Annotations rendered as DOM overlays before Playwright captures.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "example": "node examples/example-script.js",
    "replay": "node snippets/replay-all-specs.js"
  },
  "devDependencies": {
    "playwright": "^1.40.0"
  },
  "files": [
    "snippets/",
    "examples/",
    "SKILL.md",
    "README.md"
  ],
  "keywords": [
    "screenshot",
    "annotation",
    "playwright",
    "documentation",
    "ui-docs"
  ]
}
